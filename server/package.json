{
  "name": "js-trainer-server",
  "version": "1.0.0",
  "description": "Backend API for JS Infinite Trainer",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^8.1.1",
    "@neondatabase/serverless": "^0.9.3",
    "@sentry/node": "^10.52.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.30.10",
    "fastify": "^4.27.0",
    "pino-pretty": "^13.1.3",
    "resend": "^6.12.3",
    "stripe": "^22.1.1",
    "tsx": "^4.11.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.21.4",
    "typescript": "^5.4.5"
  }
}
