{
  "name": "js-trainer-server",
  "version": "1.0.0",
  "description": "Backend API for JS Infinite Trainer",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test:integration": "tsx --test src/tests/integration.test.ts",
    "test:integration:prod": "TEST_URL=https://perfect-curiosity-production-b689.up.railway.app tsx --test src/tests/integration.test.ts",
    "test:security": "tsx --test src/tests/security-contract.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@neondatabase/serverless": "^1.1.0",
    "@sentry/node": "^10.52.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "pino-pretty": "^13.1.3",
    "resend": "^6.12.3",
    "stripe": "^22.1.1",
    "tsx": "^4.11.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "@esbuild-kit/core-utils@3.3.2": {
      "esbuild": "0.25.12"
    }
  }
}
